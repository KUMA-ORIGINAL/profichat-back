DEBUG=1
SECRET_KEY=abc
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1 [::1]

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=django_db
POSTGRES_HOST=database
POSTGRES_PORT=5432

GET_CERTS=False                          # True для получения сертификатов (обязательно укажите email в CERTBOT_EMAIL
CERTBOT_EMAIL=example@example.com        # Email для регистрации certbot
DOMAIN=exemple.com                       # Домен на котором вы разворачиваете

MEDCRM_API_KEY=your-medcrm-api-key-here  # API-ключ для интеграции с MedCRM
SENTRY_DSN=                              # DSN из Sentry (пустое = отключён)
TELEGRAM_BOT_TOKEN=                      # Токен бота для уведомлений
TELEGRAM_AUTH_BOT_TOKEN=                 # Токен бота для авторизации (по умолчанию берётся TELEGRAM_BOT_TOKEN)
TELEGRAM_AUTH_WEBHOOK_SECRET=            # Секрет в URL webhook для Telegram auth-бота
TELEGRAM_AUTH_BOT_USERNAME=              # Username бота без @, например my_auth_bot
TELEGRAM_AUTH_SESSION_TTL_SECONDS=300    # Время жизни сессии входа через Telegram